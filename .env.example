# Sentinel prime - Environment Configuration

# ===== REQUIRED FOR PRODUCTION =====
# GitHub OAuth (Required for authentication)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# AI Providers (Required for AI-powered analysis)
GROQ_API_KEY=your-groq-api-key-from-groq-console

# ===== OPTIONAL CONFIGURATIONS =====

# Database (Supabase - Optional for data persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Local AI (Ollama) - Alternative to Groq, no API key needed
OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1

# Authentication (Legacy - not used with GitHub OAuth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Payments (Stripe - Optional for paid plans)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_PRICE_PROFESSIONAL=price_professional_19
STRIPE_PRICE_ENTERPRISE=price_enterprise_99

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting & Performance
MAX_SCAN_CHARS=10000
OLLAMA_TIMEOUT_MS=180000
GROQ_TIMEOUT_MS=30000
SCAN_CACHE_MS=60000

# Frontend
CORS_ORIGIN=http://localhost:3000

# ===== GETTING STARTED =====
# 1. Create GitHub OAuth App: https://github.com/settings/developers
#    - Callback URL: https://your-domain.com/auth/callback
# 2. Get Groq API Key: https://console.groq.com/
#    - Model used: llama-3.1-8b-instant
# 3. Set the two required variables above and restart

# Security
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
